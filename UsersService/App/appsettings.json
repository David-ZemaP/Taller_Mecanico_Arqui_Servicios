{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}",
    "ExpirationInMinutes": 480
  },
  "Smtp": {
    "Enabled": true,
    "Host": "${SMTP_HOST}",
    "Port": "${SMTP_PORT}",
    "Username": "${SMTP_USERNAME}",
    "Password": "${SMTP_PASSWORD}",
    "From": "${SMTP_FROM}",
    "TestRecipient": "${SMTP_TEST_RECIPIENT}",
    "EnableSsl": "true",
    "TimeoutMs": "100000"
  },
  "ConnectionStrings": {
    "DefaultConnection": "${CONNECTION_STRING}"
  }
}
