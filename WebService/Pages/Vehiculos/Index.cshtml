        function bindAutocomplete(inputId, resultsId, urlBuilder, onSelect) {
            var input = document.getElementById(inputId);
            var results = document.getElementById(resultsId);
            if (!input || !results) return;

            var timeoutId;
            input.addEventListener('input', function () {
                clearTimeout(timeoutId);
                var term = this.value.trim();
                if (term.length < 1) {
                    results.style.display = 'none';
                    results.innerHTML = '';
                    return;
                }

                timeoutId = setTimeout(function () {
                    fetch(urlBuilder(term))
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            results.innerHTML = '';
                            if (!data || data.length === 0) {
                                results.style.display = 'none';
                                return;
                            }

                            data.forEach(function (item) {
                                var div = document.createElement('div');
                                div.className = 'autocomplete-item';
                                div.textContent = item.text;
                                div.addEventListener('click', function (e) {
                                    e.preventDefault();
                                    onSelect(item);
                                    results.style.display = 'none';
                                });
                                results.appendChild(div);
                            });

                            results.style.display = 'block';
                        });
                }, 300);
            });

            document.addEventListener('click', function (e) {
                if (!input.contains(e.target)) {
                    results.style.display = 'none';
                }
            });
        }

        bindAutocomplete('vehiculoClienteSearch', 'vehiculoClienteResults', function (term) {
            return '/OrdenTrabajo?handler=BuscarClientes&term=' + encodeURIComponent(term);
        }, function (cliente) {
