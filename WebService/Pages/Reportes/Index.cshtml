@page
@model Taller_Mecanico_WebService.Pages.Reportes.IndexModel
@{
    ViewData["Title"] = "Reportes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white">
            <i class="bi bi-graph-up me-2"></i>Reportes
        </h1>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-lg h-100" style="background-color: var(--bg-card); border: 1px solid #2a2a3e;">
                <div class="card-body text-center py-4">
                    <i class="bi bi-people-fill" style="font-size: 3.5rem; color: #0dcaf0;"></i>
                    <h4 class="text-white mt-3">Clientes y Vehículos</h4>
                    <p class="text-muted">Listado de clientes registrados con sus vehículos asociados. Filtros por nombre/CI y marca.</p>
                    <a asp-page="/Reportes/ClientesVehiculos" class="btn btn-outline-info w-100 mt-2">
                        <i class="bi bi-search me-2"></i>Ver Reporte
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-lg h-100" style="background-color: var(--bg-card); border: 1px solid #2a2a3e;">
                <div class="card-body text-center py-4">
                    <i class="bi bi-bar-chart-fill" style="font-size: 3.5rem; color: var(--color-teal);"></i>
                    <h4 class="text-white mt-3">Servicios en Órdenes</h4>
                    <p class="text-muted">Análisis estadístico de servicios por período. Incluye gráfico y totales recaudados.</p>
                    <a asp-page="/Reportes/AnalyticaServicios" class="btn btn-teal w-100 mt-2 text-white">
                        <i class="bi bi-graph-up me-2"></i>Ver Reporte
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
