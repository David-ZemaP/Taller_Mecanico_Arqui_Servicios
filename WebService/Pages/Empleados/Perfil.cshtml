@page "{id}"
@model WebService.Pages.Empleados.PerfilModel
@using WebService.Models
@{
    ViewData["Title"] = "Perfil de Empleado";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2 class="text-teal fw-bold">Perfil del Empleado</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Empleados" class="btn btn-outline-secondary text-white">Volver</a>
        </div>
    </div>

    @if (Model.Empleado != null)
    {
        <!-- Información Personal -->
        <div class="card-dark p-4 shadow-sm mb-4" style="border-top: 4px solid #20c997;">
            <h5 class="text-white border-bottom border-secondary pb-2 mb-3">
                <i class="bi bi-person-vcard text-teal me-2"></i>Información Personal
            </h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted-dark">Nombre Completo</label>
                    <p class="text-white fs-5 mb-0">@Model.Empleado.NombreCompleto</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted-dark">Cédula de Identidad</label>
                    <p class="text-white mb-0">@Model.Empleado.Ci @Model.Empleado.CiComplemento</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted-dark">Teléfono</label>
                    <p class="text-white mb-0"><i class="bi bi-telephone text-teal me-2"></i>@Model.Empleado.Telefono</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted-dark">Correo Electrónico</label>
                    <p class="text-white mb-0">@Model.Empleado.Email</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted-dark">Tipo de Empleado</label>
                    <p class="mb-0">
                        <span class="badge @(Model.Empleado.TipoEmpleado == "Mecanico" ? "bg-warning text-dark" : "bg-info")">
                            @Model.Empleado.TipoEmpleado
                        </span>
                    </p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted-dark">Estado Laboral</label>
                    <p class="mb-0">
                        <span class="badge @(Model.Empleado.EstadoLaboral == "Activo" ? "bg-success" : "bg-secondary")">
                            @Model.Empleado.EstadoLaboral
                        </span>
                    </p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label text-muted-dark">Fecha de Contratación</label>
                    <p class="text-white mb-0"><i class="bi bi-calendar3 text-teal me-2"></i>@Model.Empleado.FechaContratacion.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Datos del Empleado (Salario) -->
        <div class="card-dark p-4 shadow-sm mb-4" style="border-top: 4px solid #20c997;">
            <h5 class="text-white border-bottom border-secondary pb-2 mb-3">
                <i class="bi bi-cash text-teal me-2"></i>Información Salarial
            </h5>
            <div class="row">
                @if (Model.Empleado.TipoEmpleado == "Mecanico")
                {
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted-dark">Salario por Hora</label>
                        <p class="text-white fs-5 mb-0">@(Model.Empleado.SalarioPorHora?.ToString("N2") ?? "No especificado") Bs</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted-dark">Especialidad</label>
                        <p class="text-white mb-0">@(Model.Empleado.Especialidad ?? "No especificada")</p>
                    </div>
                }
                else
                {
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted-dark">Salario Mensual</label>
                        <p class="text-white fs-5 mb-0">@(Model.Empleado.SalarioMensual?.ToString("N2") ?? "No especificado") Bs</p>
                    </div>
                }
            </div>
        </div>

        <!-- Órdenes de Trabajo -->
        <div class="card-dark p-4 shadow-sm mb-4" style="border-top: 4px solid #20c997;">
            <h5 class="text-white border-bottom border-secondary pb-2 mb-3">
                <i class="bi bi-wrench text-teal me-2"></i>Órdenes de Trabajo
            </h5>
            
            @if (Model.OrdenesTrabajo != null && Model.OrdenesTrabajo.Any())
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover">
                        <thead class="border-bottom border-secondary">
                            <tr>
                                <th class="text-teal">#</th>
                                <th class="text-teal">Vehículo</th>
                                <th class="text-teal">Fecha Ingreso</th>
                                <th class="text-teal">Fecha Entrega</th>
                                <th class="text-teal">Estado</th>
                                <th class="text-teal">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int contador = 1;
                                foreach (var orden in Model.OrdenesTrabajo)
                                {
                                    <tr class="border-bottom border-secondary">
                                        <td><span class="badge bg-secondary">@(contador++)</span></td>
                                        <td class="text-white">@orden.VehiculoPlaca</td>
                                        <td class="text-light">@orden.FechaIngreso.ToString("dd/MM/yyyy")</td>
                                        <td class="text-light">@(orden.FechaEntrega?.ToString("dd/MM/yyyy") ?? "—")</td>
                                        <td>
                                            <span class="badge bg-@(orden.EstadoTrabajo == "Completada" ? "success" : orden.EstadoTrabajo == "EnProceso" ? "warning" : "secondary")">
                                                @orden.EstadoTrabajo
                                            </span>
                                        </td>
                                        <td class="text-teal">@orden.Total.ToString("N2") Bs</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted-dark">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    No hay órdenes de trabajo asignadas a este empleado.
                </div>
            }
        </div>
    }
    else
    {
        <div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-light">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title text-danger">
                            <i class="bi bi-x-circle-fill me-2"></i>Error
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">@Model.ErrorMessage</p>
                    </div>
                    <div class="modal-footer border-secondary">
                        <a href="/Empleados" class="btn btn-teal">Volver</a>
                    </div>
                </div>
            </div>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                var modal = new bootstrap.Modal(document.getElementById('errorModal'));
                modal.show();
            });
        </script>
    }
</div>