@page
@model Taller_Mecanico_WebService.Pages.UsuariosModel
@{
    ViewData["Title"] = "Usuarios del Sistema";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-teal fw-bold mb-0">Usuarios del Sistema</h2>
        <p class="text-muted-dark">Gestiona los accesos al sistema.</p>
    </div>
    <button type="button" class="btn btn-teal px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalCrear">
        <i class="bi bi-plus-lg me-2"></i>Nuevo usuario
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.MensajeExito) || TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@(Model.MensajeExito ?? TempData["Exito"]?.ToString())
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.MensajeError) || TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@(Model.MensajeError ?? TempData["Error"]?.ToString())
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card-dark p-4 shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0" style="background-color: transparent;">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th class="text-teal pb-3">Correo electrónico</th>
                    <th class="text-teal pb-3">Usuario</th>
                    <th class="text-teal pb-3">Tipo</th>
                    <th class="text-teal pb-3">Último acceso</th>
                    <th class="text-teal pb-3">Estado</th>
                    <th class="text-teal pb-3 text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Usuarios.Any())
                {
                    @foreach (var item in Model.Usuarios)
                    {
                        <tr class="border-bottom border-secondary">
                            <td class="text-light">@item.Email</td>
                            <td class="text-white fw-semibold">@item.Username</td>
                            <td>
                                <span class="badge @(item.EsCliente ? "bg-info" : "bg-primary")">
                                    @(item.EsCliente ? "Cliente" : "Empleado")
                                </span>
                            </td>
                            <td class="text-light">@(item.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-danger")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                                @if (item.RequiereCambioPassword)
                                {
                                    <span class="badge bg-warning ms-1" title="Requiere cambio de contraseña">
                                        <i class="bi bi-key"></i>
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <form method="post" asp-page-handler="ResetPassword" class="d-inline">
                                    <input type="hidden" name="id" value="@item.UsuarioLoginId" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning text-warning border-secondary" title="Reiniciar contraseña">
                                        <i class="bi bi-key-fill"></i>
                                    </button>
                                </form>
                                @if (item.Activo)
                                {
                                    <form method="post" asp-page-handler="Eliminar" class="d-inline ms-1"
                                          onsubmit="return confirm('¿Desactivar este usuario?')">
                                        <input type="hidden" name="id" value="@item.UsuarioLoginId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-secondary" title="Desactivar usuario">
                                            <i class="bi bi-person-x"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted-dark py-5">
                            <i class="bi bi-person-x fs-2 d-block mb-2 text-secondary"></i>
                            No hay usuarios registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal: Crear usuario -->
<div class="modal fade" id="modalCrear" tabindex="-1" aria-labelledby="modalCrearLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-dark text-light border border-secondary">
            <form method="post" asp-page-handler="Crear">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-teal fw-bold" id="modalCrearLabel">
                        <i class="bi bi-person-plus me-2"></i>Nuevo Usuario
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FormCrear.Nombres" class="form-label text-teal">Nombres *</label>
                            <input asp-for="FormCrear.Nombres" class="form-control bg-dark text-white border-secondary" placeholder="Juan Carlos" />
                            <span asp-validation-for="FormCrear.Nombres" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FormCrear.PrimerApellido" class="form-label text-teal">Primer apellido *</label>
                            <input asp-for="FormCrear.PrimerApellido" class="form-control bg-dark text-white border-secondary" placeholder="Pérez" />
                            <span asp-validation-for="FormCrear.PrimerApellido" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FormCrear.SegundoApellido" class="form-label text-teal">Segundo apellido</label>
                            <input asp-for="FormCrear.SegundoApellido" class="form-control bg-dark text-white border-secondary" placeholder="García" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FormCrear.Email" class="form-label text-teal">Correo electrónico *</label>
                            <input asp-for="FormCrear.Email" type="email" class="form-control bg-dark text-white border-secondary" placeholder="usuario@email.com" />
                            <span asp-validation-for="FormCrear.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FormCrear.Nivel" class="form-label text-teal">Rol *</label>
                            <select asp-for="FormCrear.Nivel" class="form-select bg-dark text-white border-secondary">
                                <option value="">Seleccionar rol...</option>
                                <option value="Parcial">Empleado - Acceso Parcial</option>
                                <option value="Completo">Empleado - Acceso Completo</option>
                                <option value="Gerente">Gerente</option>
                            </select>
                            <span asp-validation-for="FormCrear.Nivel" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FormCrear.EmpleadoId" class="form-label text-teal">ID Empleado</label>
                            <input asp-for="FormCrear.EmpleadoId" type="number" class="form-control bg-dark text-white border-secondary" placeholder="ID del empleado en el sistema" />
                        </div>
                    </div>

                    <div class="alert alert-info mt-3 small">
                        <i class="bi bi-info-circle me-2"></i>
                        El nombre de usuario se genera automáticamente (inicial + apellido). La contraseña temporal se enviará al correo.
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-teal">
                        <i class="bi bi-person-plus me-2"></i>Crear usuario
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
