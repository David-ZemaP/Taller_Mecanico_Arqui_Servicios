@page "{id}"
@model WebService.Pages.Clientes.PerfilModel
@{
    ViewData["Title"] = "Perfil de Cliente";
}
<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>Perfil de Cliente</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Clientes" class="btn btn-secondary">Volver</a>
        </div>
    </div>

    @if (Model.Cliente != null)
    {
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Información del Cliente</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">ID</label>
                        <p class="form-control-plaintext">@Model.Cliente.UsuarioLoginId</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Cliente ID</label>
                        <p class="form-control-plaintext">@(Model.Cliente.ClienteId?.ToString() ?? "N/A")</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Email</label>
                        <p class="form-control-plaintext">@Model.Cliente.Email</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Estado</label>
                        <p class="form-control-plaintext">
                            @if (Model.Cliente.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Requiere Cambio de Contraseña</label>
                        <p class="form-control-plaintext">
                            @if (Model.Cliente.RequiereCambioPassword)
                            {
                                <span class="badge bg-warning">Sí</span>
                            }
                            else
                            {
                                <span class="badge bg-success">No</span>
                            }
                        </p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Último Acceso</label>
                        <p class="form-control-plaintext">@(Model.Cliente.UltimoAcceso?.ToString("g") ?? "Nunca")</p>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <a href="/Clientes/Editar?id=@Model.Cliente.UsuarioLoginId" class="btn btn-primary">Editar</a>
                <a href="/Clientes" class="btn btn-secondary">Cancelar</a>
            </div>
        </div>
    }
    else
    {
        <div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-light">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title text-danger">
                            <i class="bi bi-x-circle-fill me-2"></i>Error
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">@Model.ErrorMessage</p>
                    </div>
                    <div class="modal-footer border-secondary">
                        <a href="/Clientes" class="btn btn-teal">Volver</a>
                    </div>
                </div>
            </div>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                var modal = new bootstrap.Modal(document.getElementById('errorModal'));
                modal.show();
            });
        </script>
    }
</div>
