@page
@model WebService.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}
<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>Clientes</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Clientes/Crear" class="btn btn-primary">Agregar Cliente</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Clientes.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Último Acceso</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model.Clientes)
                {
                    <tr>
                        <td>@cliente.UsuarioLoginId</td>
                        <td>@cliente.Email</td>
                        <td>
                            @if (cliente.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </td>
                        <td>@(cliente.UltimoAcceso?.ToString("g") ?? "Nunca")</td>
                        <td>
                            <a href="/Clientes/Perfil?id=@cliente.UsuarioLoginId" class="btn btn-sm btn-info">Ver</a>
                            <a href="/Clientes/Editar?id=@cliente.UsuarioLoginId" class="btn btn-sm btn-warning">Editar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <strong>Sin clientes</strong>
            No hay clientes registrados en el sistema.
        </div>
    }
</div>
