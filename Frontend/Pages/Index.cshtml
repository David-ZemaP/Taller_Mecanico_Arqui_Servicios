@page
@model IndexModel
@using Taller_Mecanico_Arqui.Frontend.Enums
@{
    ViewData["Title"] = "Inicio";
    var rawAccessLevel = User.FindFirst("NivelAcceso")?.Value ?? User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var isCliente = Enum.TryParse<NivelAcceso>(rawAccessLevel, true, out var parsedCliente) && parsedCliente == NivelAcceso.Cliente;
    var isParcial = Enum.TryParse<NivelAcceso>(rawAccessLevel, true, out var parsedParcial) && parsedParcial == NivelAcceso.Parcial;
    var isCompleto = Enum.TryParse<NivelAcceso>(rawAccessLevel, true, out var parsedCompleto) && parsedCompleto == NivelAcceso.Completo;
    var isGerente = Enum.TryParse<NivelAcceso>(rawAccessLevel, true, out var parsedGerente) && parsedGerente == NivelAcceso.Gerente;
}

<div class="container mt-2">
    <div class="text-center mb-5">
        <i class="bi bi-wrench-adjustable text-teal" style="font-size: 4rem;"></i>
        <h1 class="display-4 fw-bold text-white mt-3">Taller <span class="text-teal">Mecánico</span></h1>
        <p class="lead text-muted-dark">Sistema integral para gestionar clientes, vehículos y servicios.</p>
    </div>

    @if (isGerente)
    {
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card-dark p-4 text-center shadow-sm h-100 d-flex flex-column" style="border-top: 4px solid #0dcaf0;">
                    <i class="bi bi-person-badge fs-1 text-info mb-3"></i>
                    <h3 class="text-white fw-bold">Empleados</h3>
                    <p class="text-muted-dark flex-grow-1">Alta y control de empleados del taller.</p>
                    <a asp-page="/Empleados/Index" class="btn btn-outline-info w-100 mt-auto shadow-sm">Ir a Empleados</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-dark p-4 text-center shadow-sm h-100 d-flex flex-column" style="border-top: 4px solid #ffc107;">
                    <i class="bi bi-person-gear fs-1 text-warning mb-3"></i>
                    <h3 class="text-white fw-bold">Usuarios</h3>
                    <p class="text-muted-dark flex-grow-1">Administración de accesos y cuentas.</p>
                    <a asp-page="/Usuarios" class="btn btn-outline-warning w-100 mt-auto shadow-sm">Ir a Usuarios</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-dark p-4 text-center shadow-sm h-100 d-flex flex-column" style="border-top: 4px solid #20c997;">
                    <i class="bi bi-graph-up fs-1 text-teal mb-3"></i>
                    <h3 class="text-white fw-bold">Reportes</h3>
                    <p class="text-muted-dark flex-grow-1">Seguimiento de órdenes y métricas del taller.</p>
                    <a asp-page="/Reportes/Index" class="btn btn-teal w-100 mt-auto text-white shadow-sm">Ir a Reportes</a>
                </div>
            </div>
        </div>
    }

    @if (isCompleto || isParcial)
    {
        <div class="card-dark p-4 shadow-sm border-0 mb-4">
            <h5 class="text-white border-bottom border-secondary pb-3 mb-4">
                <i class="bi bi-lightning-charge text-warning me-2"></i>Acciones rápidas
            </h5>
            <div class="d-flex flex-wrap gap-3 justify-content-center">
                <a asp-page="/Clientes/Index" class="btn btn-outline-light border-secondary">
                    <i class="bi bi-person-plus me-2 text-info"></i>Nuevo Cliente
                </a>
                <a asp-page="/Vehiculos/Index" class="btn btn-outline-light border-secondary">
                    <i class="bi bi-car-front-fill me-2 text-warning"></i>Ingresar Vehículo
                </a>
                <a asp-page="/ordentrabajo/Index" class="btn btn-outline-light border-secondary">
                    <i class="bi bi-tools me-2 text-teal"></i>Abrir orden
                </a>
            </div>
        </div>
    }

    @if (isCliente)
    {
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card-dark p-4 text-center shadow-sm h-100 d-flex flex-column" style="border-top: 4px solid #20c997;">
                    <i class="bi bi-person-circle fs-1 text-teal mb-3"></i>
                    <h3 class="text-white fw-bold">Mi perfil</h3>
                    <p class="text-muted-dark flex-grow-1">Consulta tus datos, vehículos y órdenes de trabajo.</p>
                    <a asp-page="/Clientes/Perfil" class="btn btn-teal w-100 mt-auto text-white shadow-sm">Ir a mi perfil</a>
                </div>
            </div>
        </div>
    }
</div>
