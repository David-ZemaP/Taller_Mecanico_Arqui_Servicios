@page
@model Taller_Mecanico_Arqui.Pages.UsuariosModel
@{
    ViewData["Title"] = "Usuarios del Sistema";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-teal fw-bold mb-0">Usuarios del Sistema</h2>
        <p class="text-muted-dark">Gestiona los accesos al sistema.</p>
    </div>
</div>

<div class="card-dark p-4 shadow-sm">
    <div class="alert alert-info text-center mb-0">
        <i class="bi bi-info-circle me-2"></i>
        <strong>Funcionalidad en desarrollo.</strong> La gestión de usuarios está siendo migrada a endpoints de API.
        Esta página estará disponible una vez que los endpoints de UsersService estén implementados.
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index: 9999;">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@section Scripts {
}
