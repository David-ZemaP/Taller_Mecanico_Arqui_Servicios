@page
@model Taller_Mecanico_Arqui.Pages.Empleados.IndexModel
@using Taller_Mecanico_Arqui.Frontend.Enums
@using Taller_Mecanico_Arqui.Frontend.Adapters
@{
    ViewData["Title"] = "Empleados";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index: 9999;">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["EmailWarning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index: 9999;">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["EmailWarning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-teal fw-bold mb-0">Gestión de empleados</h2>
        <p class="text-muted-dark">Administra los empleados registrados en el taller.</p>
    </div>
    <button type="button" class="btn btn-teal px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#empleadoModal" onclick="limpiarFormulario()">
        <i class="bi bi-plus-lg me-2"></i>Nuevo empleado
    </button>
</div>

<div class="d-flex flex-wrap gap-2 mb-4">
    <button type="button" onclick="filtrarEmpleados('todos')" class="btn @(Model.FiltroActual == "todos" ? "btn-teal" : "btn-outline-secondary text-white")">Todos</button>
    <button type="button" onclick="filtrarEmpleados('mecanicos')" class="btn @(Model.FiltroActual == "mecanicos" ? "btn-teal" : "btn-outline-secondary text-white")">Solo mecánicos</button>
    <button type="button" onclick="filtrarEmpleados('administradores')" class="btn @(Model.FiltroActual == "administradores" ? "btn-teal" : "btn-outline-secondary text-white")">Solo administradores</button>
</div>

<div class="card-dark p-4 shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0" style="background-color: transparent;">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th class="text-teal pb-3">#</th>
                    <th class="text-teal pb-3">Nombre</th>
                    <th class="text-teal pb-3">Tipo</th>
                    <th class="text-teal pb-3">Teléfono</th>
                    <th class="text-teal pb-3">Correo electrónico</th>
                    <th class="text-teal pb-3">Fecha de contratación</th>
                    <th class="text-teal pb-3">Estado</th>
                    <th class="text-teal pb-3 text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Empleados != null && Model.Empleados.Any())
                {
                    int contador = 1;
                    @foreach (var item in Model.Empleados)
                    {
                        <tr class="border-bottom border-secondary">
                            <td><span class="badge bg-secondary">@(contador++)</span></td>
                            <td class="fw-semibold text-white">@item.NombreCompleto</td>
                            <td class="text-light">@item.Cargo</td>
                            <td class="text-light">@item.Telefono</td>
                            <td class="text-light">@item.Email</td>
                            <td class="text-light">@(item.FechaContratacion?.ToString("dd/MM/yyyy") ?? "")</td>
                            <td>
                                <span class="badge @(item.EstadoLaboral == "Activo" ? "bg-success" : "bg-secondary")">
                                    @item.EstadoLaboral
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1">
                                    <button type="button" class="btn btn-icon btn-sm btn-outline-info border-secondary"
                                            title="Detalles" data-bs-toggle="modal" data-bs-target="#detailsModal"
                                            onclick="verDetalles(@item.EmpleadoId)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button type="button" class="btn btn-icon btn-sm btn-outline-secondary text-teal border-secondary"
                                            title="Editar" data-bs-toggle="modal" data-bs-target="#empleadoModal"
                                            onclick="editarEmpleado(@item.EmpleadoId)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-icon btn-sm btn-outline-danger border-secondary"
                                            title="Eliminar" data-bs-toggle="modal" data-bs-target="#deleteModal"
                                            onclick="prepararEliminar(@item.EmpleadoId, '@Html.Raw(item.NombreCompleto.Replace("'", "\\'"))')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted-dark py-5">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                            @Model.MensajeSinResultados
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL 1: Formulario Create/Edit (reutilizable) -->
<div class="modal fade" id="empleadoModal" tabindex="-1" aria-labelledby="empleadoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content bg-dark text-light p-3">
            <form method="post" asp-page-handler="Save">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="empleadoModalLabel">Crear empleado</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
        <div class="modal-body py-4 px-4">
            <input type="hidden" asp-for="FormDto.EmpleadoId" id="formEmpleadoId" value="0" />

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="FormDto.Cargo" class="form-label text-teal">Tipo de empleado *</label>
                    <select asp-for="FormDto.Cargo" class="form-select form-control-dark" id="formCargo">
                        <option value="Mecanico">Mecánico</option>
                        <option value="Administrador">Administrador</option>
                    </select>
                    <span asp-validation-for="FormDto.Cargo" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 mb-3 mb-md-0">
                    <label asp-for="FormDto.Nombres" class="form-label text-teal">Nombre *</label>
                    <input asp-for="FormDto.Nombres" class="form-control form-control-dark" id="formNombres" />
                    <span asp-validation-for="FormDto.Nombres" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3 mb-md-0">
                    <label asp-for="FormDto.PrimerApellido" class="form-label text-teal">Primer apellido *</label>
                    <input asp-for="FormDto.PrimerApellido" class="form-control form-control-dark" id="formPrimerApellido" />
                    <span asp-validation-for="FormDto.PrimerApellido" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="FormDto.SegundoApellido" class="form-label text-teal">Segundo apellido</label>
                    <input asp-for="FormDto.SegundoApellido" class="form-control form-control-dark" id="formSegundoApellido" />
                    <span asp-validation-for="FormDto.SegundoApellido" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6 mb-3 mb-md-0">
                    <label asp-for="FormDto.CiNumero" class="form-label text-teal">CI *</label>
                    <input asp-for="FormDto.CiNumero" class="form-control form-control-dark" id="formCiNumero" />
                    <span asp-validation-for="FormDto.CiNumero" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FormDto.CiComplemento" class="form-label text-teal">Complemento CI</label>
                    <input asp-for="FormDto.CiComplemento" class="form-control form-control-dark" id="formCiComplemento" />
                    <span asp-validation-for="FormDto.CiComplemento" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6 mb-3 mb-md-0">
                    <label asp-for="FormDto.Telefono" class="form-label text-teal">Teléfono *</label>
                    <input asp-for="FormDto.Telefono" class="form-control form-control-dark" id="formTelefono" />
                    <span asp-validation-for="FormDto.Telefono" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FormDto.Email" class="form-label text-teal">Correo electrónico</label>
                    <input asp-for="FormDto.Email" class="form-control form-control-dark" id="formEmail" />
                    <span asp-validation-for="FormDto.Email" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6 mb-3 mb-md-0">
                    <label asp-for="FormDto.FechaContratacion" class="form-label text-teal">Fecha de contratación *</label>
                    <input asp-for="FormDto.FechaContratacion" type="date" class="form-control form-control-dark" id="formFechaContratacion" />
                    <span asp-validation-for="FormDto.FechaContratacion" class="text-danger"></span>
                </div>
            </div>
        </div>
                <div class="modal-footer border-secondary py-3 px-4">
                    <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-teal" id="modalSubmitBtn">Crear empleado</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL 2: Detalles -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content bg-dark text-light p-3">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="detailsModalLabel">Detalles del empleado</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body py-4 px-4" id="detailsContent">
                <div class="text-center py-4">
                    <div class="spinner-border text-teal" role="status"></div>
                </div>
            </div>
            <div class="modal-footer border-secondary py-3 px-4">
                <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL 3: Eliminar -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light p-3">
            <form method="post" asp-page-handler="Delete">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="deleteModalLabel">Eliminar empleado</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body py-4 px-4">
                    <input type="hidden" name="id" id="deleteEmpleadoId" />
                    <div class="text-center mb-3">
                        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
                    </div>
                    <p class="text-center">¿Está seguro de eliminar al empleado <strong id="deleteEmpleadoNombre"></strong>?</p>
                    <p class="text-danger text-center mb-0">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer border-secondary py-3 px-4">
                    <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Sí, Eliminar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function filtrarEmpleados(filtro) {
            window.location.href = '?filtro=' + filtro;
        }

        function limpiarFormulario()
        {
            document.getElementById('formEmpleadoId').value = '0';
            document.getElementById('formNombres').value = '';
            document.getElementById('formPrimerApellido').value = '';
            document.getElementById('formSegundoApellido').value = '';
            document.getElementById('formCiNumero').value = '';
            document.getElementById('formCiComplemento').value = '';
            document.getElementById('formTelefono').value = '';
            document.getElementById('formEmail').value = '';
            document.getElementById('formFechaContratacion').value = '';
            document.getElementById('formCargo').value = 'Mecanico';
            document.getElementById('empleadoModalLabel').textContent = 'Crear empleado';
            document.getElementById('modalSubmitBtn').textContent = 'Crear empleado';
        }

        function editarEmpleado(id) {
            fetch('?handler=Empleado&id=' + id)
                .then(r => r.json())
                .then(data => {
                    if (data.error) { alert(data.error); return; }
                    document.getElementById('formEmpleadoId').value = data.empleadoId;
                    document.getElementById('formNombres').value = data.nombres;
                    document.getElementById('formPrimerApellido').value = data.primerApellido;
                    document.getElementById('formSegundoApellido').value = data.segundoApellido || '';
                    document.getElementById('formCiNumero').value = data.ciNumero;
                    document.getElementById('formCiComplemento').value = data.ciComplemento || '';
                    document.getElementById('formTelefono').value = data.telefono;
                    document.getElementById('formEmail').value = data.email || '';
                    document.getElementById('formFechaContratacion').value = data.fechaContratacion;
                    document.getElementById('formCargo').value = data.cargo;
                    document.getElementById('empleadoModalLabel').textContent = 'Editar empleado';
                    document.getElementById('modalSubmitBtn').textContent = 'Actualizar empleado';
                })
                .catch(() => alert('Error al cargar los datos del empleado'));
        }

        function verDetalles(id) {
            document.getElementById('detailsContent').innerHTML = '<div class="text-center py-4"><div class="spinner-border text-teal" role="status"></div></div>';
            fetch('?handler=Empleado&id=' + id)
                .then(r => r.json())
                .then(data => {
                    if (data.error) {
                        document.getElementById('detailsContent').innerHTML = '<p class="text-danger text-center">' + data.error + '</p>';
                        return;
                    }
                    var tipoBadge = data.cargo === 'Mecanico' ? 'bg-warning text-dark' : 'bg-info';
                    var estadoBadge = data.estadoLaboral === 'Activo' ? 'bg-success' : 'bg-secondary';
                    var html = '<div class="card-dark p-3 mb-3" style="border-top: 4px solid #20c997;">' +
                        '<h6 class="text-white border-bottom border-secondary pb-2 mb-3"><i class="bi bi-person-vcard text-teal me-2"></i>Información Personal</h6>' +
                        '<dl class="row mb-0">' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Nombre Completo</dt>' +
                        '<dd class="col-sm-8 text-white fw-bold fs-5 mb-2">' + data.nombres + ' ' + data.primerApellido + ' ' + (data.segundoApellido || '') + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Carnet / CI</dt>' +
                        '<dd class="col-sm-8 text-white mb-2">' + data.ciNumero + ' ' + (data.ciComplemento || '') + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Teléfono</dt>' +
                        '<dd class="col-sm-8 text-white mb-2"><i class="bi bi-telephone text-teal me-2"></i>' + data.telefono + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Correo electrónico</dt>' +
                        '<dd class="col-sm-8 text-white mb-2">' + (data.email || '<span class="text-muted-dark fst-italic">No registrado</span>') + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Fecha Contratación</dt>' +
                        '<dd class="col-sm-8 text-white mb-2"><i class="bi bi-calendar3 text-teal me-2"></i>' + new Date(data.fechaContratacion).toLocaleDateString('es-ES') + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Tipo</dt>' +
                        '<dd class="col-sm-8 text-white mb-2"><span class="badge ' + tipoBadge + '">' + data.cargo + '</span></dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Estado Laboral</dt>' +
                        '<dd class="col-sm-8 text-white mb-2"><span class="badge ' + estadoBadge + '">' + data.estadoLaboral + '</span></dd>' +
                        '</dl></div>';

                    document.getElementById('detailsContent').innerHTML = html;
                })
                .catch(() => {
                    document.getElementById('detailsContent').innerHTML = '<p class="text-danger text-center">Error al cargar los detalles</p>';
                });
        }

        function prepararEliminar(id, nombre) {
            document.getElementById('deleteEmpleadoId').value = id;
            document.getElementById('deleteEmpleadoNombre').textContent = nombre;
        }
    </script>
}
