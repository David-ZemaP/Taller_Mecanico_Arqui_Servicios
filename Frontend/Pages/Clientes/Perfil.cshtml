@page
@model Taller_Mecanico_Arqui.Pages.Clientes.PerfilModel
@using Taller_Mecanico_Arqui.Frontend.Adapters
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12 mb-4">
            <h2 class="text-teal fw-bold mb-1">Bienvenido, @Model.Cliente?.Nombres @Model.Cliente?.PrimerApellido</h2>
            <p class="text-muted-dark">Gestiona tu información y seguimiento de tus vehículos.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card-dark p-4 shadow-sm h-100">
                <h5 class="text-teal fw-bold mb-3 border-bottom border-secondary pb-2">
                    <i class="bi bi-person-circle me-2"></i>Información Personal
                </h5>
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Nombre completo</label>
                    <p class="text-white mb-0 fs-5">@Model.Cliente?.Nombres @Model.Cliente?.PrimerApellido @Model.Cliente?.SegundoApellido</p>
                </div>
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Documento de Identidad</label>
                    <p class="text-white mb-0">@Model.Cliente?.Ci</p>
                </div>
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Teléfono</label>
                    <p class="text-white mb-0">@Model.Cliente?.Telefono</p>
                </div>
                <div class="mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Correo electrónico</label>
                    <p class="text-white mb-0">@Model.Cliente?.Email</p>
                </div>
                <div class="mb-0">
                    <label class="text-muted small text-uppercase fw-bold">Fecha de registro</label>
                    <p class="text-white mb-0">@Model.Cliente?.FechaRegistro.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card-dark p-4 shadow-sm mb-4">
                <h5 class="text-teal fw-bold mb-3 border-bottom border-secondary pb-2">
                    <i class="bi bi-car-front me-2"></i>Mis Vehículos (@Model.Cliente?.Vehiculos?.Count())
                </h5>
                @if (Model.Cliente?.Vehiculos?.Any() == true)
                {
                    <div class="row g-3">
                        @foreach (var vehiculo in Model.Cliente.Vehiculos)
                        {
                            <div class="col-md-6">
                                <div class="bg-dark rounded p-3 border border-secondary">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <span class="badge bg-light text-dark px-2 py-1 border border-secondary fs-6" style="font-family: monospace;">
                                                @vehiculo.Placa
                                            </span>
                                        </div>
                                        <span class="badge bg-secondary">@vehiculo.Color</span>
                                    </div>
                                    <p class="text-white mt-2 mb-0">@vehiculo.Marca @vehiculo.Modelo</p>
                                    <p class="text-muted small mb-0">Año: @vehiculo.Anio</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">No tienes vehículos registrados. Visita el taller para registrar uno.</p>
                }
            </div>

            <div class="card-dark p-4 shadow-sm">
                <h5 class="text-teal fw-bold mb-3 border-bottom border-secondary pb-2">
                    <i class="bi bi-clipboard2-check me-2"></i>Mis Órdenes de Trabajo (@Model.Ordenes?.Count())
                </h5>
                @if (Model.Ordenes?.Any() == true)
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0" style="background-color: transparent;">
                            <thead class="border-bottom border-secondary">
                                <tr>
                                    <th class="text-teal">#</th>
                                    <th class="text-teal">Vehículo</th>
                                    <th class="text-teal">Ingreso</th>
                                    <th class="text-teal">Entrega</th>
                                    <th class="text-teal">Estado</th>
                                    <th class="text-teal">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int contador = 1;
                                    foreach (var orden in Model.Ordenes)
                                    {
                                        <tr class="border-bottom border-secondary">
                                            <td><span class="badge bg-secondary">@(contador++)</span></td>
                                            <td>
                                                <span class="badge bg-light text-dark px-2 py-1 border border-secondary" style="font-family: monospace;">
                                                    @orden.VehiculoPlaca
                                                </span>
                                            </td>
                                            <td class="text-light">@orden.FechaIngreso.ToString("dd/MM/yyyy")</td>
                                            <td class="text-light">@orden.FechaEntrega?.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <span class="badge bg-info text-dark px-2 py-1">
                                                    @orden.EstadoTrabajo
                                                </span>
                                                <span class="badge bg-warning text-dark px-2 py-1">
                                                    @orden.EstadoPago
                                                </span>
                                            </td>
                                            <td class="text-white fw-bold">Bs. @orden.Total.ToString("F2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No tienes órdenes de trabajo registradas.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
}
