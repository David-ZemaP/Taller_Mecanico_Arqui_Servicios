@page
@model Taller_Mecanico_Arqui.Pages.ChangePasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Cambiar Contraseña";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Taller Mecánico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #1a1d2e; min-height: 100vh; display: flex; align-items: center; justify-content: center; }

        .wrapper {
            width: 440px;
            background-color: transparent;
            border: 2px solid rgba(255,255,255,.2);
            backdrop-filter: blur(15px);
            box-shadow: 0 0 20px rgba(0,0,0,.3);
            color: #fff;
            border-radius: 12px;
            padding: 35px 40px;
        }
        .wrapper h1 { font-size: 28px; text-align: center; font-weight: 700; margin-bottom: 6px; color: #20c997; }
        .wrapper .subtitle { text-align: center; font-size: 13px; color: rgba(255,255,255,.6); margin-bottom: 24px; }

        .input-box { position: relative; width: 100%; margin-bottom: 16px; }
        .input-box input {
            width: 100%; height: 44px;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.25);
            border-radius: 8px;
            font-size: 14px;
            color: #fff;
            padding: 0 40px 0 16px;
            outline: none;
        }
        .input-box input::placeholder { color: rgba(255,255,255,.5); }
        .input-box input:focus { border-color: #20c997; }
        .input-box i { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); font-size: 16px; color: rgba(255,255,255,.5); pointer-events: none; }

        .policy-box {
            background: rgba(32,201,151,.08);
            border: 1px solid rgba(32,201,151,.25);
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 20px;
            font-size: 12px;
            color: rgba(255,255,255,.75);
        }
        .policy-box ul { margin: 6px 0 0 18px; padding: 0; }
        .policy-box li { margin-bottom: 2px; }

        .btn-teal { background-color: #20c997; border-color: #20c997; color: #000; font-weight: 600; }
        .btn-teal:hover { background-color: #1aa179; border-color: #1aa179; color: #000; }

        .back-link { text-align: center; margin-top: 16px; font-size: 13px; }
        .back-link a { color: #20c997; text-decoration: none; }
        .back-link a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="wrapper">
        <h1><i class="bi bi-key me-2"></i>Cambiar Contraseña</h1>
        <p class="subtitle">Ingresa tu contraseña actual y la nueva contraseña.</p>

        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 px-3 mb-3" style="font-size:13px; border-radius:8px;">
                @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="input-box">
                <input asp-for="Input.CurrentPassword" type="password" placeholder="Contraseña actual" autocomplete="current-password" />
                <i class="bi bi-lock"></i>
            </div>
            <div class="input-box">
                <input asp-for="Input.NewPassword" type="password" placeholder="Nueva contraseña" autocomplete="new-password" />
                <i class="bi bi-lock-fill"></i>
            </div>
            <div class="input-box">
                <input asp-for="Input.ConfirmPassword" type="password" placeholder="Confirmar nueva contraseña" autocomplete="new-password" />
                <i class="bi bi-shield-lock"></i>
            </div>

            <div class="policy-box">
                <strong>Política de contraseñas:</strong>
                <ul>
                    <li>Mínimo 8 caracteres</li>
                    <li>Al menos 1 letra mayúscula</li>
                    <li>Al menos 1 letra minúscula</li>
                    <li>Al menos 1 número</li>
                    <li>Al menos 1 carácter especial (!&#64;#$%^&amp;*)</li>
                </ul>
            </div>

            <button type="submit" class="btn btn-teal w-100">
                <i class="bi bi-check2-circle me-2"></i>Cambiar Contraseña
            </button>
        </form>

        <div class="back-link">
            <a asp-page="/Index"><i class="bi bi-arrow-left me-1"></i>Volver al inicio</a>
        </div>
    </div>
</body>
</html>
