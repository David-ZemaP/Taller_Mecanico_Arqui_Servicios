@page
@model Taller_Mecanico_Arqui.Pages.ChangePasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Cambiar contraseña";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Taller Mecánico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body { 
            background-color: #1a1d2e; 
            min-height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
        }

        .wrapper {
            width: 420px;
            background-color: transparent;
            border: 2px solid rgba(255, 255, 255, .2);
            backdrop-filter: blur(15px);
            box-shadow: 0 0 10px rgba(0, 0, 0, .2);
            color: #fff;
            border-radius: 10px;
            padding: 30px 40px;
        }

        .wrapper h1 {
            font-size: 36px;
            text-align: center;
            font-weight: 700;
            margin-bottom: 10px;
            color: #20c997;
        }

        .wrapper .subtitle {
            text-align: center;
            font-size: 14px;
            color: rgba(255, 255, 255, .7);
            margin-bottom: 20px;
        }

        .info-box {
            background: rgba(32, 201, 151, 0.1);
            border: 1px solid rgba(32, 201, 151, 0.3);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            font-size: 14px;
            color: rgba(255, 255, 255, .8);
        }

        .info-box ul {
            margin: 10px 0 0 20px;
            padding: 0;
        }

        .btn-teal { 
            background-color: #20c997; 
            border-color: #20c997; 
            color: #000;
        }
        .btn-teal:hover {
            background-color: #1aa179;
            border-color: #1aa179;
            color: #000;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <h1>Función no disponible</h1>
        <p class="subtitle">El cambio de contraseña via web no está disponible actualmente</p>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="info-box">
            <strong>Nota:</strong> Esta funcionalidad requiere un endpoint API en UsersService para cambiar contraseñas.
            Mientras tanto, puedes cambiar tu contraseña iniciando sesión en el servicio de usuarios.
        </div>

        <a href="~/Clientes/Perfil" class="btn btn-teal w-100">Volver al Perfil</a>
    </div>
</body>
</html>
