@page
@model Taller_Mecanico_Arqui.Pages.Reportes.OrdenTrabajoModel
@{
    ViewData["Title"] = "Reporte Orden de Trabajo";
}

@if (Model.Orden == null)
{
    <div class="container mt-4">
        <div class="alert alert-danger">Orden no encontrada.</div>
        <a href="/ordentrabajo" class="btn btn-secondary">Volver</a>
    </div>
    return;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orden de Trabajo</title>
    <style>
        @@media print {
            body { background: white !important; }
            .no-print { display: none !important; }
            header nav .navbar-collapse,
            header nav .navbar-toggler,
            header nav .dropdown,
            header nav ul.navbar-nav {
                display: none !important;
            }
            header nav {
                background: white !important;
                border: 0 !important;
                margin-bottom: 10px !important;
                padding: 0 !important;
            }
            header nav .container {
                justify-content: flex-start !important;
            }
            header nav .navbar-brand {
                color: #157347 !important;
                font-weight: 700 !important;
            }
            footer { display: none !important; }
            @@page { margin: 1cm; size: A4; }
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #1a1a2e;
            color: #e0e0e0;
            padding: 20px;
        }
        .header-taller {
            text-align: center;
            color: #20c997;
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 25px;
        }
        .reporte-container {
            max-width: 700px;
            margin: 0 auto;
            background: #16213e;
            border-radius: 12px;
            padding: 30px;
        }
        .info-row {
            display: flex;
            gap: 20px;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px solid #2a4a6e;
        }
        .info-item {
            flex: 1;
        }
        .info-item label {
            color: #666;
            font-size: 0.75rem;
            text-transform: uppercase;
        }
        .info-item span {
            font-size: 1.1rem;
            color: #fff;
        }
        .section {
            margin-bottom: 20px;
        }
        .section-title {
            color: #888;
            font-size: 0.8rem;
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        .table {
            width: 100%;
            border-collapse: collapse;
        }
        .table th {
            background: #1a2744;
            color: #aaa;
            padding: 8px 12px;
            text-align: left;
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: normal;
        }
        .table td {
            padding: 10px 12px;
            border-bottom: 1px solid #1a2744;
            font-size: 0.95rem;
        }
        .table tr:nth-child(even) td {
            background: rgba(26, 39, 68, 0.3);
        }
        .table .right {
            text-align: right;
        }
        .table .center {
            text-align: center;
        }
        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #20c997;
            color: #000;
            padding: 15px 20px;
            border-radius: 8px;
            margin-top: 20px;
        }
        .total-row .label {
            font-size: 1rem;
            font-weight: bold;
        }
        .total-row .amount {
            font-size: 1.5rem;
            font-weight: bold;
        }
        .no-print {
            text-align: center;
            margin-top: 30px;
        }
        .no-print button {
            background: #20c997;
            border: none;
            color: #000;
            padding: 12px 30px;
            border-radius: 8px;
            font-size: 1rem;
            cursor: pointer;
            margin: 5px;
        }
        .no-print button.secondary {
            background: #6c757d;
            color: #fff;
        }
    </style>
</head>
<body>
    <div class="header-taller">TALLER MECÁNICO</div>
    <div class="reporte-container">
        <div class="info-row">
            <div class="info-item">
                <label>Cliente</label><br>
                <span>@Model.Orden.ClienteNombre</span><br>
                <span style="font-size: 0.95rem; color: #bdbdbd;">CI: @Model.Orden.ClienteCi</span>
            </div>
            <div class="info-item">
                <label>Vehículo</label><br>
                <span style="font-family: monospace;">@Model.Orden.Placa</span>
            </div>
        </div>

        @if (Model.Orden.Productos != null && Model.Orden.Productos.Any())
        {
            <div class="section">
                <div class="section-title">Productos</div>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th class="center">Cant.</th>
                            <th class="right">Precio</th>
                            <th class="right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Orden.Productos)
                        {
                            <tr>
                                <td>@(string.IsNullOrEmpty(p.Nombre) ? $"Producto #{p.ProductoId}" : p.Nombre)</td>
                                <td class="center">@p.Cantidad</td>
                                <td class="right">Bs. @p.PrecioUnitario.ToString("F2")</td>
                                <td class="right">Bs. @p.Subtotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Orden.Servicios != null && Model.Orden.Servicios.Any())
        {
            <div class="section">
                <div class="section-title">Servicios</div>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Servicio</th>
                            <th class="center">Cant.</th>
                            <th class="right">Precio</th>
                            <th class="right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Orden.Servicios)
                        {
                            <tr>
                                <td>@(string.IsNullOrEmpty(s.Nombre) ? $"Servicio #{s.ServicioId}" : s.Nombre)</td>
                                <td class="center">@s.Cantidad</td>
                                <td class="right">Bs. @s.PrecioUnitario.ToString("F2")</td>
                                <td class="right">Bs. @s.Subtotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="total-row">
            <div class="label">TOTAL</div>
            <div class="amount">Bs. @Model.Orden.Total.ToString("F2")</div>
        </div>

        <div class="no-print">
            <button onclick="window.print()">
                <i class="bi bi-printer me-2"></i>Imprimir
            </button>
            <button onclick="window.close()" class="secondary">
                <i class="bi bi-x-lg me-2"></i>Cerrar
            </button>
        </div>
    </div>
</body>
</html>