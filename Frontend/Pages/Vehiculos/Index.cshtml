@page
@model Taller_Mecanico_Arqui.Pages.Vehiculo.IndexModel
@using Taller_Mecanico_Arqui.Frontend.Enums
@using Taller_Mecanico_Arqui.Frontend.Adapters
@{
    ViewData["Title"] = "Vehículos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-teal fw-bold mb-0">Gestión de vehículos</h2>
        <p class="text-muted-dark">Administra los vehículos registrados en el taller.</p>
    </div>
    @if (Model.CanModify)
    {
        <button class="btn btn-teal px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#vehiculoModal" onclick="limpiarFormulario()">
            <i class="bi bi-plus-lg me-2"></i>Nuevo vehículo
        </button>
    }
</div>

<div class="card-dark p-4 shadow-sm">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0" style="background-color: transparent;">
            <thead class="border-bottom border-secondary">
                <tr>
                    <th class="text-teal pb-3">#</th>
                    <th class="text-teal pb-3">Placa</th>
                    <th class="text-teal pb-3">Marca</th>
                    <th class="text-teal pb-3">Modelo</th>
                    <th class="text-teal pb-3">Año</th>
                    <th class="text-teal pb-3">Propietario</th>
                    <th class="text-teal pb-3 text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Vehiculos != null && Model.Vehiculos.Any())
                {
                    int contador = 1;
                    @foreach (var item in Model.Vehiculos)
                    {
                        <tr class="border-bottom border-secondary">
                            <td><span class="badge bg-secondary">@(contador++)</span></td>
                            <td><span class="badge bg-light text-dark px-2 py-1 border border-secondary shadow-sm" style="font-family: monospace;">@item.Placa</span></td>
                            <td class="text-white fw-semibold">@item.Marca</td>
                            <td class="text-light">@item.Modelo</td>
                            <td class="text-light">@item.Anio</td>
                            <td class="text-light"><i class="bi bi-person text-teal me-2"></i>@item.ClienteNombre</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1">
                                    <button type="button" class="btn btn-icon btn-sm btn-outline-info border-secondary" title="Detalles" data-bs-toggle="modal" data-bs-target="#detailsModal" onclick="verDetalles(@item.VehiculoId)"><i class="bi bi-eye"></i></button>
                                    @if (Model.CanModify)
                                    {
                                        <button type="button" class="btn btn-icon btn-sm btn-outline-secondary text-teal border-secondary" title="Editar" data-bs-toggle="modal" data-bs-target="#vehiculoModal" onclick="editarVehiculo(@item.VehiculoId)"><i class="bi bi-pencil"></i></button>
                                        <button type="button" class="btn btn-icon btn-sm btn-outline-danger border-secondary" title="Eliminar" data-bs-toggle="modal" data-bs-target="#deleteModal" onclick="prepararEliminar(@item.VehiculoId, '@Html.Raw(item.Placa.Replace("'", "\\'"))')"><i class="bi bi-trash"></i></button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted-dark py-5"><i class="bi bi-car-front fs-2 d-block mb-2 text-secondary"></i>No hay vehículos registrados aún.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL: Vehículo (reutilizable) -->
<div class="modal fade" id="vehiculoModal" tabindex="-1" aria-labelledby="vehiculoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-dark text-light p-3">
            <form method="post" asp-page-handler="Save">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="vehiculoModalLabel">Crear vehículo</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body py-4 px-4">
                    <input type="hidden" asp-for="FormDto.VehiculoId" id="formVehiculoId" value="0" />
                    <input type="hidden" asp-for="FormDto.ClienteId" id="formClienteId" />

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="FormDto.Placa" class="form-label text-teal">Placa *</label>
                            <input asp-for="FormDto.Placa" class="form-control form-control-dark" id="formPlaca" />
                            <span asp-validation-for="FormDto.Placa" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-teal">Propietario *</label>
                            <input type="text" id="formClienteSearch" class="form-control form-control-dark" placeholder="Buscar por CI o nombre..." autocomplete="off" />
                            <div id="clienteResults" class="autocomplete-results"></div>
                            <span asp-validation-for="FormDto.ClienteId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4 mb-3 mb-md-0">
                            <label class="form-label text-teal">Marca *</label>
                            <input type="text" id="formMarcaSearch" class="form-control form-control-dark" placeholder="Buscar marca..." autocomplete="off" />
                            <div id="marcaResults" class="autocomplete-results"></div>
                            <input type="hidden" asp-for="FormDto.MarcaId" id="formMarca" />
                            <span asp-validation-for="FormDto.MarcaId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3 mb-md-0">
                            <label class="form-label text-teal">Modelo *</label>
                            <input type="text" id="formModeloSearch" class="form-control form-control-dark" placeholder="Buscar modelo..." autocomplete="off" />
                            <div id="modeloResults" class="autocomplete-results"></div>
                            <input type="hidden" asp-for="FormDto.ModeloId" id="formModelo" />
                            <span asp-validation-for="FormDto.ModeloId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-teal">Año</label>
                            <input asp-for="FormDto.Anio" type="number" class="form-control form-control-dark" id="formAnio" />
                            <span asp-validation-for="FormDto.Anio" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-teal">Color *</label>
                            <input type="text" id="formColorSearch" class="form-control form-control-dark" placeholder="Buscar color..." autocomplete="off" />
                            <div id="colorResults" class="autocomplete-results"></div>
                            <input type="hidden" asp-for="FormDto.ColorVehiculoId" id="formColor" />
                            <span asp-validation-for="FormDto.ColorVehiculoId" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary py-3 px-4">
                    <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-teal" id="modalSubmitBtn">Crear vehículo</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL 2: Detalles -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content bg-dark text-light p-3">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="detailsModalLabel">Detalles del vehículo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body py-4 px-4" id="detailsContent">
                <div class="text-center py-4"><div class="spinner-border text-teal" role="status"></div></div>
            </div>
            <div class="modal-footer border-secondary py-3 px-4">
                <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL 3: Eliminar -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light p-3">
            <form method="post" asp-page-handler="Delete">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="deleteModalLabel">Eliminar vehículo</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body py-4 px-4">
                    <input type="hidden" name="id" id="deleteVehiculoId" />
                    <div class="text-center mb-3"><i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i></div>
                    <p class="text-center">¿Está seguro de eliminar el vehículo con placa <strong id="deleteVehiculoPlaca"></strong>?</p>
                    <p class="text-danger text-center mb-0">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer border-secondary py-3 px-4">
                    <button type="button" class="btn btn-outline-secondary text-white" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Sí, Eliminar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function limpiarFormulario() {
            document.getElementById('formVehiculoId').value = '0';
            document.getElementById('formPlaca').value = '';
            document.getElementById('formClienteId').value = '';
            document.getElementById('formClienteSearch').value = '';
            document.getElementById('formMarca').value = '';
            document.getElementById('formMarcaSearch').value = '';
            document.getElementById('formModelo').value = '';
            document.getElementById('formModeloSearch').value = '';
            document.getElementById('formAnio').value = '';
            document.getElementById('formColor').value = '';
            document.getElementById('formColorSearch').value = '';
            document.getElementById('vehiculoModalLabel').textContent = 'Crear vehículo';
            document.getElementById('modalSubmitBtn').textContent = 'Crear vehículo';
        }

        function editarVehiculo(id) {
            fetch('?handler=Vehiculo&id=' + id)
                .then(r => r.json())
                .then(data => {
                    if (data.error) { alert(data.error); return; }
                    document.getElementById('formVehiculoId').value = data.vehiculoId;
                    document.getElementById('formPlaca').value = data.placa || '';
                    document.getElementById('formClienteId').value = data.clienteId || '';
                    document.getElementById('formClienteSearch').value = data.clienteNombre || '';
                    document.getElementById('formMarca').value = data.marcaId || '';
                    document.getElementById('formMarcaSearch').value = data.marca || '';
                    document.getElementById('formModelo').value = data.modeloId || '';
                    document.getElementById('formModeloSearch').value = data.modelo || '';
                    document.getElementById('formAnio').value = data.anio || '';
                    document.getElementById('formColor').value = data.colorVehiculoId || '';
                    document.getElementById('formColorSearch').value = data.color || '';
                    document.getElementById('vehiculoModalLabel').textContent = 'Editar vehículo';
                    document.getElementById('modalSubmitBtn').textContent = 'Actualizar vehículo';
                })
                .catch(() => alert('Error al cargar los datos del vehículo'));
        }

        function verDetalles(id) {
            document.getElementById('detailsContent').innerHTML = '<div class="text-center py-4"><div class="spinner-border text-teal" role="status"></div></div>';
            fetch('?handler=Vehiculo&id=' + id)
                .then(r => r.json())
                .then(data => {
                    if (data.error) {
                        document.getElementById('detailsContent').innerHTML = '<p class="text-danger text-center">' + data.error + '</p>';
                        return;
                    }
                    document.getElementById('detailsContent').innerHTML =
                        '<div class="card-dark p-3 mb-3" style="border-top: 4px solid #20c997;">' +
                        '<h6 class="text-white border-bottom border-secondary pb-2 mb-3"><i class="bi bi-car-front text-teal me-2"></i>Información del Vehículo</h6>' +
                        '<dl class="row mb-0">' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Placa</dt><dd class="col-sm-8 text-white fw-bold fs-5 mb-2"><span class="badge bg-light text-dark px-2 py-1" style="font-family: monospace;">' + data.placa + '</span></dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Propietario</dt><dd class="col-sm-8 text-white mb-2"><i class="bi bi-person text-teal me-2"></i>' + data.clienteNombre + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Marca</dt><dd class="col-sm-8 text-white mb-2">' + data.marca + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Modelo</dt><dd class="col-sm-8 text-white mb-2">' + data.modelo + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Color</dt><dd class="col-sm-8 text-white mb-2">' + data.color + '</dd>' +
                        '<dt class="col-sm-4 text-muted-dark fw-normal mb-2">Año</dt><dd class="col-sm-8 text-white mb-2">' + data.anio + '</dd>' +
                        '</dl></div>';
                })
                .catch(() => { document.getElementById('detailsContent').innerHTML = '<p class="text-danger text-center">Error al cargar los detalles</p>'; });
        }

        function prepararEliminar(id, placa) {
            document.getElementById('deleteVehiculoId').value = id;
            document.getElementById('deleteVehiculoPlaca').textContent = placa;
        }

        // Datos de catálogos desde el servidor
        var marcasData = [
            @Html.Raw(string.Join(",", Model.Marcas.Select(m => $"{{id: {m.Id}, nombre: '{m.Nombre.Replace("'", "\\'")}'}}")))
        ];
        var modelosData = [
            @Html.Raw(string.Join(",", Model.Modelos.Select(m => $"{{id: {m.Id}, nombre: '{m.Nombre.Replace("'", "\\'")}', marca: '{m.MarcaNombre.Replace("'", "\\'")}'}}") ))
        ];
        var coloresData = [
            @Html.Raw(string.Join(",", Model.Colores.Select(c => $"{{id: {c.Id}, nombre: '{c.Nombre.Replace("'", "\\'")}'}}") ))
        ];

        // Cliente search
        let clienteSearchTimeout;
        document.getElementById('formClienteSearch').addEventListener('input', function() {
            clearTimeout(clienteSearchTimeout);
            var term = this.value.trim();
            if (term.length < 1) { document.getElementById('clienteResults').style.display = 'none'; return; }
            clienteSearchTimeout = setTimeout(function() {
                fetch('?handler=BuscarClientes&term=' + encodeURIComponent(term))
                    .then(r => r.json())
                    .then(data => {
                        var container = document.getElementById('clienteResults');
                        container.innerHTML = '';
                        if (!data || data.length === 0) { container.style.display = 'none'; return; }
                        data.forEach(function(c) {
                            var div = document.createElement('div');
                            div.className = 'autocomplete-item';
                            div.textContent = c.text;
                            div.addEventListener('click', function(e) {
                                e.preventDefault();
                                document.getElementById('formClienteId').value = c.id;
                                document.getElementById('formClienteSearch').value = c.text;
                                container.style.display = 'none';
                            });
                            container.appendChild(div);
                        });
                        container.style.display = 'block';
                    });
            }, 300);
        });

        // Marca search
        let marcaSearchTimeout;
        document.getElementById('formMarcaSearch').addEventListener('input', function() {
            clearTimeout(marcaSearchTimeout);
            var term = this.value.trim().toLowerCase();
            var container = document.getElementById('marcaResults');
            container.innerHTML = '';
            if (term.length < 1) { container.style.display = 'none'; return; }
            var filtered = marcasData.filter(m => m.nombre.toLowerCase().includes(term));
            if (filtered.length === 0) { container.style.display = 'none'; return; }
            filtered.forEach(function(m) {
                var div = document.createElement('div');
                div.className = 'autocomplete-item';
                div.textContent = m.nombre;
                div.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.getElementById('formMarca').value = m.id;
                    document.getElementById('formMarcaSearch').value = m.nombre;
                    container.style.display = 'none';
                });
                container.appendChild(div);
            });
            container.style.display = 'block';
        });

        // Modelo search
        let modeloSearchTimeout;
        document.getElementById('formModeloSearch').addEventListener('input', function() {
            clearTimeout(modeloSearchTimeout);
            var term = this.value.trim().toLowerCase();
            var container = document.getElementById('modeloResults');
            container.innerHTML = '';
            if (term.length < 1) { container.style.display = 'none'; return; }
            var filtered = modelosData.filter(m => m.nombre.toLowerCase().includes(term) || m.marca.toLowerCase().includes(term));
            if (filtered.length === 0) { container.style.display = 'none'; return; }
            filtered.forEach(function(m) {
                var div = document.createElement('div');
                div.className = 'autocomplete-item';
                div.textContent = m.marca + ' - ' + m.nombre;
                div.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.getElementById('formModelo').value = m.id;
                    document.getElementById('formModeloSearch').value = m.nombre;
                    container.style.display = 'none';
                });
                container.appendChild(div);
            });
            container.style.display = 'block';
        });

        // Color search
        let colorSearchTimeout;
        document.getElementById('formColorSearch').addEventListener('input', function() {
            clearTimeout(colorSearchTimeout);
            var term = this.value.trim().toLowerCase();
            var container = document.getElementById('colorResults');
            container.innerHTML = '';
            if (term.length < 1) { container.style.display = 'none'; return; }
            var filtered = coloresData.filter(c => c.nombre.toLowerCase().includes(term));
            if (filtered.length === 0) { container.style.display = 'none'; return; }
            filtered.forEach(function(c) {
                var div = document.createElement('div');
                div.className = 'autocomplete-item';
                div.textContent = c.nombre;
                div.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.getElementById('formColor').value = c.id;
                    document.getElementById('formColorSearch').value = c.nombre;
                    container.style.display = 'none';
                });
                container.appendChild(div);
            });
            container.style.display = 'block';
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(e) {
            if (!document.getElementById('formClienteSearch').contains(e.target)) {
                document.getElementById('clienteResults').style.display = 'none';
            }
            if (!document.getElementById('formMarcaSearch').contains(e.target) && !document.getElementById('marcaResults').contains(e.target)) {
                document.getElementById('marcaResults').style.display = 'none';
            }
            if (!document.getElementById('formModeloSearch').contains(e.target) && !document.getElementById('modeloResults').contains(e.target)) {
                document.getElementById('modeloResults').style.display = 'none';
            }
            if (!document.getElementById('formColorSearch').contains(e.target) && !document.getElementById('colorResults').contains(e.target)) {
                document.getElementById('colorResults').style.display = 'none';
            }
        });

        // Auto-show modal on validation errors
        @if (!ViewData.ModelState.IsValid)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                var modal = new bootstrap.Modal(document.getElementById('vehiculoModal'));
                modal.show();
                document.getElementById('vehiculoModalLabel').textContent = 'Editar vehículo';
                document.getElementById('modalSubmitBtn').textContent = 'Actualizar vehículo';
            });
            </text>
        }
    </script>
}
