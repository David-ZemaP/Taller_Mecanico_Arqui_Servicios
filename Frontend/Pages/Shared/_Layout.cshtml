@using Taller_Mecanico_Arqui.Frontend.Enums
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isHomeSection = string.Equals(currentPage, "/Index", System.StringComparison.OrdinalIgnoreCase) || string.IsNullOrEmpty(currentPage);
    var isClientesSection = currentPage.StartsWith("/Clientes", System.StringComparison.OrdinalIgnoreCase);
    var isVehiculosSection = currentPage.StartsWith("/Vehiculos", System.StringComparison.OrdinalIgnoreCase);
    var isEmpleadosSection = currentPage.StartsWith("/Empleados", System.StringComparison.OrdinalIgnoreCase);
    var isOrdenesSection = currentPage.StartsWith("/ordentrabajo", System.StringComparison.OrdinalIgnoreCase);
    var isServiciosProductosSection = currentPage.StartsWith("/ServiciosProductos", System.StringComparison.OrdinalIgnoreCase);
    var isReportesSection = currentPage.StartsWith("/Reportes", System.StringComparison.OrdinalIgnoreCase);
    
    // Get user's access level from claims
    var nivelAccesoClaim = User.FindFirst("NivelAcceso");
    var userLevel = NivelAcceso.Parcial; // Default
    if (nivelAccesoClaim != null && Enum.TryParse<NivelAcceso>(nivelAccesoClaim.Value, out var parsedLevel))
    {
        userLevel = parsedLevel;
    }
    
    // Determine visibility based on access level
    var isCliente = userLevel == NivelAcceso.Cliente;
    var canViewClientes = userLevel == NivelAcceso.Completo || userLevel == NivelAcceso.Parcial;
    var canViewVehiculos = userLevel == NivelAcceso.Completo || userLevel == NivelAcceso.Parcial;
    var canViewServiciosProductos = userLevel == NivelAcceso.Completo;
    var canViewOrdenes = userLevel == NivelAcceso.Completo || userLevel == NivelAcceso.Parcial;
    var canViewEmpleados = userLevel == NivelAcceso.Completo || userLevel == NivelAcceso.Gerente;
    var canViewUsuarios = userLevel == NivelAcceso.Completo || userLevel == NivelAcceso.Gerente;
    var canViewReportes = userLevel == NivelAcceso.Completo || userLevel == NivelAcceso.Gerente;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Taller Mecánico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Taller_Mecanico_Arqui.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container--default .select2-selection--single {
            background-color: #212529;
            border: 1px solid #495057;
            color: #fff;
            height: 38px;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: #fff;
            line-height: 36px;
        }
        .select2-dropdown { background-color: #212529; border: 1px solid #495057; color: #fff;}
        .select2-container--default .select2-results__option[aria-selected=true] { background-color: #343a40; }
        .select2-container--default .select2-results__option--highlighted[aria-selected] { background-color: #20c997; color: white; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom border-dark mb-4 py-3" style="background-color: var(--bg-card);">
            <div class="container">
                <a class="navbar-brand text-teal fw-bold fs-4" asp-area="" asp-page="/Index">
                    <i class="bi bi-car-front-fill me-2"></i>PITSTOP
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Alternar navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link text-light fw-semibold nav-icon-link @(isHomeSection ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/Index" title="Inicio" aria-label="Inicio">
                                <i class="bi bi-house-door"></i>
                                    <span class="nav-link-label">Inicio</span>
                            </a>
                        </li>
                        @if (canViewClientes)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(isClientesSection ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/Clientes/Index" title="Clientes" aria-label="Clientes">
                                    <i class="bi bi-people"></i>
                                    <span class="nav-link-label">Clientes</span>
                                </a>
                            </li>
                        }
                        @if (canViewVehiculos)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(isVehiculosSection ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/Vehiculos/Index" title="Vehículos" aria-label="Vehículos">
                                    <i class="bi bi-car-front"></i>
                                    <span class="nav-link-label">Vehículos</span>
                                </a>
                            </li>
                        }
                        @if (canViewEmpleados)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(isEmpleadosSection ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/Empleados/Index" title="Empleados" aria-label="Empleados">
                                    <i class="bi bi-person-badge"></i>
                                    <span class="nav-link-label">Empleados</span>
                                </a>
                            </li>
                        }
                        @if (canViewServiciosProductos)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(isServiciosProductosSection ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/ServiciosProductos/Index" title="Servicios y Productos" aria-label="Servicios y Productos">
                                    <i class="bi bi-box-seam"></i>
                                    <span class="nav-link-label">Servicios y Productos</span>
                                </a>
                            </li>
                        }
                        @if (canViewUsuarios)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(currentPage.StartsWith("/Usuarios", System.StringComparison.OrdinalIgnoreCase) ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/Usuarios" title="Usuarios" aria-label="Usuarios">
                                    <i class="bi bi-person-gear"></i>
                                    <span class="nav-link-label">Usuarios</span>
                                </a>
                            </li>
                        }
                        @if (canViewOrdenes)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(isOrdenesSection ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/ordentrabajo/Index" title="Órdenes de Trabajo" aria-label="Órdenes de Trabajo">
                                    <i class="bi bi-clipboard2-data"></i>
                                    <span class="nav-link-label">Órdenes de Trabajo</span>
                                </a>
                            </li>
                        }
                        @if (canViewReportes)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(isReportesSection ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/Reportes/Index" title="Reportes" aria-label="Reportes">
                                    <i class="bi bi-graph-up"></i>
                                    <span class="nav-link-label">Reportes</span>
                                </a>
                            </li>
                        }
                        @if (isCliente)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold nav-icon-link @(currentPage.Contains("Perfil", System.StringComparison.OrdinalIgnoreCase) ? "nav-icon-open active" : string.Empty)" asp-area="" asp-page="/Clientes/Perfil" title="Mi Perfil" aria-label="Mi Perfil">
                                    <i class="bi bi-person"></i>
                                    <span class="nav-link-label">Mi Perfil</span>
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary text-white dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle me-1"></i>
                            @User.Identity?.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end bg-dark border-secondary">
                            @if (isCliente)
                            {
                                <li>
                                    <a class="dropdown-item text-light" asp-page="/ChangePassword">
                                        <i class="bi bi-key me-2"></i>Cambiar contraseña
                                    </a>
                                </li>
                            }
                            <li>
                                <form method="post" asp-page="/Logout">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-secondary mt-auto py-3 shadow-lg" style="background-color: #1e1e2d;">
        <div class="container text-center text-muted-dark">
            &copy; 2026 - Sistema de Gestión de Taller Mecánico - 
            <a asp-area="" asp-page="/Privacy" class="text-teal text-decoration-none">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
